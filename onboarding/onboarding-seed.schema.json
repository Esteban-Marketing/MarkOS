{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MARKOS Onboarding Seed v2.1",
  "type": "object",
  "required": ["metadata", "company", "product", "audience", "competition", "market", "content"],
  "properties": {
    "metadata": {
      "type": "object",
      "properties": {
        "generated": { "type": "string", "format": "date-time" },
        "version": { "type": "string" },
        "completeness_score": { "type": "number", "minimum": 0, "maximum": 6 }
      }
    },
    "company": {
      "type": "object",
      "required": ["business_model"],
      "properties": {
        "name": { "type": "string" },
        "industry": { "type": "string" },
        "country": { "type": "string" },
        "founded": { "type": "string" },
        "mission": { "type": "string" },
        "brand_values": { "type": "array", "items": { "type": "string" }, "maxItems": 3 },
        "tone_of_voice": { "type": "string", "enum": ["Formal", "Balanced", "Casual", "Playful"] },
        "primary_language": { "type": "string" },
        "business_model": {
          "type": "string",
          "enum": ["B2B", "B2C", "B2B2C", "DTC", "Marketplace", "SaaS", "Agents-aaS"],
          "description": "Primary go-to-market model. Drives example selection for all LLM prompt injections."
        }
      }
    },
    "product": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "primary_benefit": { "type": "string" },
        "top_features": { "type": "array", "items": { "type": "string" }, "maxItems": 3 },
        "price_range": { "type": "string" },
        "main_objection": { "type": "string" },
        "pricing_model": {
          "type": "string",
          "enum": ["One-time", "Subscription", "Usage-based", "Freemium", "Hybrid"],
          "description": "Always collected. Affects copywriting tone and channel strategy."
        },
        "sales_cycle": {
          "type": "string",
          "enum": ["Short (<30d)", "Medium (30-90d)", "Long (90d+)", "Enterprise (180d+)"],
          "description": "Conditional: B2B, B2B2C, SaaS, Agents-aaS only."
        },
        "avg_order_value": {
          "type": "string",
          "enum": ["<$50", "$50-$200", "$200-$1000", "$1000+"],
          "description": "Conditional: B2C, DTC only. Drives paid acquisition strategy."
        },
        "consumption_metric": {
          "type": "string",
          "description": "Conditional: SaaS (Usage-based), Agents-aaS. e.g. 'API calls', 'tasks run', 'seats'."
        }
      }
    },
    "audience": {
      "type": "object",
      "properties": {
        "segment_name": { "type": "string" },
        "age_range": { "type": "string" },
        "job_title": { "type": "string" },
        "pain_points": { "type": "array", "items": { "type": "string" }, "maxItems": 3 },
        "online_hangouts": { "type": "string" },
        "vocabulary": { "type": "string" },
        "decision_maker": {
          "type": "string",
          "description": "Conditional: B2B, B2B2C, SaaS, Agents-aaS. Who approves the purchase? e.g. 'Economic Buyer', 'Champion', 'Technical Evaluator'."
        },
        "purchase_frequency": {
          "type": "string",
          "enum": ["One-time", "Occasional", "Regular", "Habitual"],
          "description": "Conditional: B2C, DTC, Marketplace. How often does this audience buy?"
        },
        "lifestyle_triggers": {
          "type": "string",
          "description": "Conditional: B2C, DTC. Life events or moments that trigger the purchase decision."
        },
        "supply_side": {
          "type": "string",
          "description": "Conditional: Marketplace only. Description of the seller/creator/service-provider side."
        },
        "demand_side": {
          "type": "string",
          "description": "Conditional: Marketplace only. Description of the buyer/consumer side."
        }
      }
    },
    "competition": {
      "type": "object",
      "properties": {
        "competitors": {
          "type": "array",
          "maxItems": 3,
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string" },
              "differentiator": { "type": "string" },
              "gap": { "type": "string" }
            }
          }
        }
      }
    },
    "market": {
      "type": "object",
      "properties": {
        "maturity": { "type": "string", "enum": ["Emerging", "Growth", "Mature", "Declining"] },
        "biggest_trend": { "type": "string" },
        "seasonal_patterns": { "type": "string" },
        "regulatory_concern": { "type": "string" }
      }
    },
    "content": {
      "type": "object",
      "properties": {
        "best_piece_url": { "type": "string" },
        "active_channels": { "type": "array", "items": { "type": "string" } },
        "monthly_output": { "type": "string" },
        "best_format": { "type": "string" }
      }
    },
    "brand_input": {
      "type": "object",
      "description": "Phase 73 brand inputs and human insight modeling (optional, additive to existing onboarding data)",
      "properties": {
        "brand_profile": {
          "type": "object",
          "description": "Primary brand identity (D-01, D-03)",
          "properties": {
            "primary_name": { "type": "string", "description": "Brand name" },
            "mission_statement": { "type": "string", "description": "Mission/purpose" },
            "brand_values": { "type": "array", "items": { "type": "string" }, "description": "Core values" },
            "tone_of_voice": { "type": "string", "description": "Communication style" }
          },
          "required": ["primary_name"]
        },
        "audience_segments": {
          "type": "array",
          "minItems": 2,
          "maxItems": 5,
          "description": "2-5 audience segments with structured pains, needs, expectations (D-01, D-02, D-03)",
          "items": {
            "type": "object",
            "properties": {
              "segment_name": { "type": "string", "description": "Segment name" },
              "segment_id": { "type": "string", "description": "Unique segment identifier" },
              "pains": {
                "type": "array",
                "description": "Pain points with required rationale (D-02)",
                "items": {
                  "type": "object",
                  "properties": {
                    "pain": { "type": "string" },
                    "rationale": { "type": "string", "description": "Why this pain matters (required, D-02)" }
                  },
                  "required": ["pain", "rationale"]
                }
              },
              "needs": {
                "type": "array",
                "description": "Needs with required rationale (D-02)",
                "items": {
                  "type": "object",
                  "properties": {
                    "need": { "type": "string" },
                    "rationale": { "type": "string", "description": "Why this need is critical (required, D-02)" }
                  },
                  "required": ["need", "rationale"]
                }
              },
              "expectations": {
                "type": "array",
                "description": "Expectations with required rationale (D-02)",
                "items": {
                  "type": "object",
                  "properties": {
                    "expectation": { "type": "string" },
                    "rationale": { "type": "string", "description": "Why this expectation matters (required, D-02)" }
                  },
                  "required": ["expectation", "rationale"]
                }
              },
              "desired_outcomes": {
                "type": "array",
                "description": "Desired business outcomes (D-03)",
                "items": { "type": "string" }
              }
            },
            "required": ["segment_name", "segment_id"]
          }
        }
      }
    }
  }
}

