{
  "name": "@markos/sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for the MarkOS marketing operating system — generated from contracts/openapi.json.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "generate": "node ../../scripts/sdk/prepare-openapi.cjs && openapi-typescript ../../contracts/openapi.sdk.json -o src/schema.d.ts",
    "build": "tsc",
    "smoke": "node ../../test/sdk/ts-smoke.test.js"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.4.0"
  },
  "license": "MIT"
}
