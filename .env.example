# MarkOS environment variables
# Copy this file to .env for local/dev instances.
# For hosted/CI instances, add the same values in your platform secret manager.
# Never commit real secrets.

# ============================================================================
# Required Secrets For Full MarkOS Operation
# ============================================================================

# AI drafting: provide at least ONE provider key.
# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Google Gemini
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.5-flash

# Vector + relational persistence
# Required for onboarding persistence, literacy ingest/admin, and vector-backed readiness.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# UPSTASH_VECTOR_REST_URL=https://your-upstash-index.upstash.io
# UPSTASH_VECTOR_REST_TOKEN=your-upstash-vector-token

# Hosted runtime auth contract
# Required in hosted environments for config/status/migration guarded endpoints.
# This is usually the JWT audience used by your Supabase project, commonly "authenticated".
# MARKOS_SUPABASE_AUD=authenticated

# ============================================================================
# Recommended Secrets
# ============================================================================

# Linear integration
# Required only if you use POST /linear/sync or automatic Linear issue creation.
# LINEAR_API_KEY=lin_api_xxxxxxxxx
# Preferred: team key for issue routing
# LINEAR_TEAM_KEY=MKT
# Optional alternative to team key
# LINEAR_TEAM_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Optional deterministic assignee mapping by ITM domain (JSON object)
# Example: {"OPS":"ops@company.com","CNT":"content@company.com","ACQ":"growth@company.com"}
# LINEAR_ASSIGNEE_MAP={}
# Optional fallback assignee when the domain map has no match
# LINEAR_ASSIGNEE_DEFAULT=owner@company.com

# PostHog telemetry
# Required only if you want server-side telemetry emission.
# POSTHOG_API_KEY=phc_xxxxxxxxxxxxxxxxxxxx
# POSTHOG_HOST=https://us.i.posthog.com

# Tavily enrichment
# Required only for competitor/domain enrichment and Tavily-backed scraping.
# TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxx

# Admin operations
# Required only for protected admin endpoints and admin maintenance operations.
# MARKOS_ADMIN_SECRET=replace-with-a-long-random-secret

# ============================================================================
# Recommended Runtime Configuration
# ============================================================================

# Namespace vector collections by project/client.
# If omitted, MarkOS falls back to "markos".
# MARKOS_VECTOR_PREFIX=markos

# Rollout mode for migration/runtime hardening flows.
# Allowed values: dry-run, dual-write, cloud-primary
# MARKOS_ROLLOUT_MODE=dry-run

# Explicit telemetry toggle. Set to false to disable MarkOS telemetry.
# MARKOS_TELEMETRY=true

# Optional fallback key for read-only Supabase checks in some code paths.
# This is not a substitute for SUPABASE_SERVICE_ROLE_KEY when write/admin operations are required.
# SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional Node version override for CLI/runtime checks.
# MARKOS_NODE_VERSION_OVERRIDE=22.13.0

# ============================================================================
# CI / GitHub Actions Secrets
# ============================================================================

# Required only in GitHub Actions for the UI quality workflow / Chromatic publish.
# Add this in repository or organization Actions secrets for CI, or local env for manual Chromatic publishes.
CHROMATIC_PROJECT_TOKEN=your-chromatic-project-token

