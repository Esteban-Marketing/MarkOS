# MarkOS Client Onboarding — Environment Variables
# Copy this file to .env and fill in your values.
# The .env file is gitignored and should NEVER be committed.

# ── AI Providers ─────────────────────────────────────────────────────────────
# Required for AI draft generation during client onboarding.
# Provide at least ONE of the following keys.

# OpenAI (https://platform.openai.com/api-keys)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Anthropic (https://console.anthropic.com/settings/keys)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Google Gemini (https://aistudio.google.com/app/apikey)
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.5-flash

# ── Vector Memory (Supabase + Upstash) ──────────────────────────────────────
# Required for vector-backed persistence and retrieval.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# UPSTASH_VECTOR_REST_URL=https://your-upstash-index.upstash.io
# UPSTASH_VECTOR_REST_TOKEN=your-upstash-token

# ── Per-Client Overrides ─────────────────────────────────────────────────────
# Set a unique slug per client to namespace vector collections.
# If not set, the server derives this from the company name in the form.
# PROJECT_SLUG=acme-corp

# ── Linear Sync (Phase 29) ───────────────────────────────────────────────────
# Required for POST /linear/sync
# LINEAR_API_KEY=lin_api_xxxxxxxxx
# LINEAR_TEAM_KEY=MKT
# Optional: LINEAR_TEAM_ID can be used instead of LINEAR_TEAM_KEY
# LINEAR_TEAM_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Optional deterministic assignee mapping by ITM domain (JSON)
# Example: {"OPS":"ops@company.com","CNT":"content@company.com","ACQ":"growth@company.com"}
# LINEAR_ASSIGNEE_MAP={}
# Optional default assignee if domain-specific mapping is missing
# LINEAR_ASSIGNEE_DEFAULT=owner@company.com

