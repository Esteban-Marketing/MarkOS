# MGSD Client Onboarding — Environment Variables
# Copy this file to .env and fill in your values.
# The .env file is gitignored and should NEVER be committed.

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required for AI draft generation during client onboarding.
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: override the model (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# ── ChromaDB ─────────────────────────────────────────────────────────────────
# Optional: override ChromaDB host (default: http://localhost:8000)
# CHROMA_HOST=http://localhost:8000

# ── Per-Client Overrides ─────────────────────────────────────────────────────
# Set a unique slug per client to namespace ChromaDB collections.
# If not set, the server derives this from the company name in the form.
# PROJECT_SLUG=acme-corp
