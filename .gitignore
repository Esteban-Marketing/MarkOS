# MarkOS gitignore

# Environment secrets — never commit these
.env
.env.local
.env.*.local

# Node modules
node_modules/

# OS
.DS_Store
Thumbs.db

# Test artifacts
tmp/

# MarkOS client overrides (private — do not commit)
.markos-local/
.markos-local/
onboarding-seed.json
.markos-install-manifest.json
.markos-install-manifest.json

# Raw upstream templates staged for install (delete after install)
.temp/

# PageIndex deep-index output (LLM-generated per file)
obsidian/.pageindex/deep/
tools/pageindex/results/
tools/pageindex/.env

# Python artifacts from PageIndex
tools/pageindex/__pycache__/
tools/pageindex/**/__pycache__/
tools/pageindex/*.pyc
