{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/crm/[objectKind]",
      "regex": "^/crm/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPobjectKind": "nxtPobjectKind"
      },
      "namedRegex": "^/crm/(?<nxtPobjectKind>[^/]+?)(?:/)?$"
    },
    {
      "page": "/crm/[objectKind]/[recordId]",
      "regex": "^/crm/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPobjectKind": "nxtPobjectKind",
        "nxtPrecordId": "nxtPrecordId"
      },
      "namedRegex": "^/crm/(?<nxtPobjectKind>[^/]+?)/(?<nxtPrecordId>[^/]+?)(?:/)?$"
    }
  ],
