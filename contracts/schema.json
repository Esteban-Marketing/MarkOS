{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://markos.app/contracts/schema.json",
  "title": "MarkOS Flow Contract",
  "description": "Canonical JSON Schema for per-flow API contract metadata. Phase 45 baseline.",
  "type": "object",
  "required": ["flow_id", "flow_name", "domain", "flow_type", "version", "openapi", "info", "paths"],
  "additionalProperties": false,
  "properties": {
    "flow_id": {
      "type": "string",
      "pattern": "^F-[0-9]{2}$",
      "description": "Canonical flow identifier matching FLOW-TAXONOMY classification map"
    },
    "flow_name": {
      "type": "string",
      "minLength": 1,
      "description": "Kebab-case flow name matching flow-registry.json entry"
    },
    "domain": {
      "type": "string",
      "enum": ["onboarding", "execution", "enrichment", "integration", "migration", "reporting", "admin"],
      "description": "Functional domain from FLOW-TAXONOMY.json locked enum set"
    },
    "flow_type": {
      "type": "string",
      "enum": ["submission", "approval", "regeneration", "query", "health_check", "sync", "record", "migration", "enrichment"],
      "description": "Flow type from FLOW-TAXONOMY.json locked enum set"
    },
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+$",
      "description": "Contract version in vN format (e.g. v1)"
    },
    "openapi": {
      "type": "string",
      "const": "3.0.3",
      "description": "OpenAPI version — fixed at 3.0.3 per D-07"
    },
    "info": {
      "type": "object",
      "required": ["title", "version"],
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        }
      }
    },
    "paths": {
      "type": "object",
      "minProperties": 1,
      "description": "OpenAPI paths object — at minimum one local_path entry required",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": "object"
        }
      }
    },
    "x-markos-meta": {
      "type": "object",
      "description": "MarkOS-specific metadata for operator tooling per D-09",
      "additionalProperties": false,
      "properties": {
        "actor": {
          "type": "string",
          "enum": ["Operator", "System", "Admin"]
        },
        "auth_local": {
          "type": "string"
        },
        "auth_hosted": {
          "type": "string"
        },
        "handler": {
          "type": "string"
        },
        "local_path": {
          "type": "string"
        },
        "hosted_path": {
          "type": "string"
        },
        "slo_tier": {
          "type": "string",
          "enum": ["critical", "standard"]
        },
        "method": {
          "type": "string",
          "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"]
        }
      }
    }
  }
}
