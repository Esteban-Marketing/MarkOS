{
  "name": "markos",
  "version": "3.3.0",
  "description": "MarkOS — the Marketing Operating System. Protocol-grade marketing infrastructure for AI-ready teams.",
  "keywords": [
    "marketing",
    "ai",
    "agents",
    "protocol",
    "markos",
    "marketing-os",
    "operating-system",
    "gsd"
  ],
  "homepage": "https://markos.esteban.marketing",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "markos": "./bin/install.cjs"
  },
  "files": [
    "bin/",
    ".agent/markos/",
    "onboarding/",
    "VERSION",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "node bin/dev-server.cjs",
    "test": "node --test test/**/*.test.js",
    "release:smoke": "node scripts/npm-pack-smoke-check.cjs",
    "gsd:refresh-manifests": "node tools/gsd-refresh-manifest.cjs",
    "build:llm": "tsc -p tsconfig.llm.json --noEmit",
    "test:llm": "node --test test/llm-adapter/**/*.test.js",
    "test:llm:coverage:core": "node --test --test-concurrency=1 --experimental-test-coverage test/llm-adapter/adapter-init.test.js test/llm-adapter/claude.test.js test/llm-adapter/openai.test.js test/llm-adapter/gemini.test.js test/llm-adapter/cost-calculator.test.js test/llm-adapter/fallback-chain.test.js test/llm-adapter/settings.test.js test/llm-adapter/telemetry.test.js",
    "verify:phase47:live": "node scripts/phase47-live-verification.cjs",
    "verify:phase47:mock": "node scripts/phase47-live-verification.cjs --mock-byok",
    "markos:llm:config": "node bin/llm-config.cjs",
    "markos:llm:status": "node bin/llm-status.cjs",
    "test:install": "node --test test/install.test.js",
    "test:patch": "node --test test/update.test.js",
    "test:onboarding": "node --test test/onboarding-server.test.js",
    "test:protocol": "node --test test/protocol.test.js",
    "verify:phase84:cutover-scan": "node scripts/phase-84/static-cutover-scan.cjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic --only-changed --exit-zero-on-changes",
    "test:ui-a11y": "node --test test/ui-a11y/**/*.test.js",
    "test:ui-security": "node --test test/ui-security/**/*.test.js",
    "test:ui-all": "npm run build-storybook && npm run test:ui-a11y && npm run test:ui-security",
    "vault:index": "node scripts/pageindex/build-vault-index.mjs",
    "vault:index:file": "bash scripts/pageindex/index-file.sh",
    "openapi:build": "node scripts/openapi/build-openapi.cjs",
    "prepublishOnly": "node -e \"console.log('Publishing MarkOS v' + require('./package.json').version + ' (human-run npm publish required)')\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/s3-request-presigner": "^3.1032.0",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sentry/nextjs": "^10.49.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.58.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@upstash/vector": "^1.2.3",
    "@vercel/edge-config": "^1.4.3",
    "@vercel/queue": "^0.1.6",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "archiver": "^7.0.1",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.3.1",
    "formidable": "^3.5.4",
    "keytar": "^7.9.0",
    "mammoth": "^1.12.0",
    "next": "^15.2.0",
    "openai": "^6.32.0",
    "openapi-fetch": "^0.17.0",
    "pdf-parse": "^2.4.5",
    "posthog-node": "^5.21.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^1.2.21",
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-interactions": "^8.6.18",
    "@storybook/addon-links": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "axe-core": "^4.10.0",
    "axe-playwright": "^1.2.3",
    "chromatic": "^16.0.0",
    "openapi-typescript": "^7.13.0",
    "storybook": "^8.6.18",
    "stripe": "^22.0.0",
    "typescript": "^5.4.0"
  }
}
