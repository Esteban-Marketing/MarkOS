{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "MarkOS design tokens — W3C DTCG format. Generated from DESIGN.md (canonical). Do not edit by hand; re-export with `npx @google/design.md export --format dtcg DESIGN.md > tokens/tokens.json`.",
  "$metadata": {
    "source": "DESIGN.md",
    "specVersion": "alpha",
    "designSystemVersion": "1.1.0",
    "lastReviewed": "2026-04-28"
  },

  "color": {
    "primary":           { "$type": "color", "$value": "#00D9A3", "$description": "Protocol Mint — signal color, single CTA per view, focus rings. <5% of any composition." },
    "primary-hover":     { "$type": "color", "$value": "#00C492" },
    "primary-pressed":   { "$type": "color", "$value": "#00B083" },
    "primary-subtle":    { "$type": "color", "$value": "rgba(0, 217, 163, 0.10)" },
    "on-primary":        { "$type": "color", "$value": "#0A0E14" },

    "secondary":         { "$type": "color", "$value": "#7B8DA6", "$description": "Vault Slate — chrome, secondary text, borders." },
    "secondary-hover":   { "$type": "color", "$value": "#8C9DB5" },
    "on-secondary":      { "$type": "color", "$value": "#0A0E14" },

    "accent":            { "$type": "color", "$value": "#FFB800", "$description": "Override Amber — warnings, override resolution, premium markers. <2% of any composition." },
    "accent-hover":      { "$type": "color", "$value": "#FFC633" },
    "on-accent":         { "$type": "color", "$value": "#0A0E14" },

    "surface":           { "$type": "color", "$value": "#0A0E14", "$description": "Kernel Black — page background. Replaces #000000 everywhere." },
    "surface-raised":    { "$type": "color", "$value": "#1A1F2A", "$description": "Process Gray — cards, panels, code-block headers." },
    "surface-overlay":   { "$type": "color", "$value": "#242B38", "$description": "Modals, popovers, toasts, command palette." },
    "surface-inverse":   { "$type": "color", "$value": "#F4F4F0", "$description": "Lino Light — light-mode equivalent." },

    "border":            { "$type": "color", "$value": "#2D3441", "$description": "Border Mist — 1px hairlines. Preferred over shadows on dark." },
    "border-strong":     { "$type": "color", "$value": "#3A4250" },
    "border-subtle":     { "$type": "color", "$value": "rgba(45, 52, 65, 0.40)" },

    "on-surface":        { "$type": "color", "$value": "#E6EDF3", "$description": "Terminal White — primary text. 16.3:1 on surface, AAA all sizes." },
    "on-surface-muted":  { "$type": "color", "$value": "#7B8DA6", "$description": "Secondary text. 5.7:1 — AA normal, AAA large." },
    "on-surface-subtle": { "$type": "color", "$value": "#6B7785", "$description": "Tertiary text, metadata, disabled. 4.6:1 — AA normal." },

    "success":           { "$type": "color", "$value": "#3FB950" },
    "success-hover":     { "$type": "color", "$value": "#4ED561" },
    "on-success":        { "$type": "color", "$value": "#0A0E14" },
    "warning":           { "$type": "color", "$value": "#FFB800" },
    "warning-hover":     { "$type": "color", "$value": "#FFC633", "$description": "Aliased to accent-hover per State · warning · aliased to accent." },
    "on-warning":        { "$type": "color", "$value": "#0A0E14", "$description": "Reserved for text on a 100% solid warning fill. On 12% alpha warning-tint surface, use color.warning itself." },
    "error":             { "$type": "color", "$value": "#F85149" },
    "error-hover":       { "$type": "color", "$value": "#FF6961" },
    "on-error":          { "$type": "color", "$value": "#0A0E14" },
    "info":              { "$type": "color", "$value": "#58A6FF" },
    "info-hover":        { "$type": "color", "$value": "#79B8FF" },
    "on-info":           { "$type": "color", "$value": "#0A0E14" },

    "light-surface":         { "$type": "color", "$value": "#F4F4F0" },
    "light-surface-raised":  { "$type": "color", "$value": "#FFFFFF" },
    "light-on-surface":      { "$type": "color", "$value": "#0A0E14" },
    "light-border":          { "$type": "color", "$value": "#D6D6D0" }
  },

  "fontFamily": {
    "mono": { "$type": "fontFamily", "$value": ["JetBrains Mono", "Source Code Pro", "Menlo", "Consolas", "monospace"] },
    "sans": { "$type": "fontFamily", "$value": ["Inter", "system-ui", "-apple-system", "Segoe UI", "Roboto", "sans-serif"] }
  },

  "fontWeight": {
    "regular":  { "$type": "fontWeight", "$value": 400 },
    "medium":   { "$type": "fontWeight", "$value": 500 },
    "semibold": { "$type": "fontWeight", "$value": 600 },
    "bold":     { "$type": "fontWeight", "$value": 700 }
  },

  "typography": {
    "display": {
      "$type": "typography",
      "$value": { "fontFamily": "{fontFamily.mono}", "fontSize": "3.052rem", "fontWeight": 700, "lineHeight": 1.05, "letterSpacing": "-0.02em" }
    },
    "h1":      { "$type": "typography", "$value": { "fontFamily": "{fontFamily.mono}", "fontSize": "2.441rem", "fontWeight": 700, "lineHeight": 1.10, "letterSpacing": "-0.015em" } },
    "h2":      { "$type": "typography", "$value": { "fontFamily": "{fontFamily.mono}", "fontSize": "1.953rem", "fontWeight": 600, "lineHeight": 1.20, "letterSpacing": "-0.01em" } },
    "h3":      { "$type": "typography", "$value": { "fontFamily": "{fontFamily.mono}", "fontSize": "1.563rem", "fontWeight": 600, "lineHeight": 1.30, "letterSpacing": "-0.005em" } },
    "h4":      { "$type": "typography", "$value": { "fontFamily": "{fontFamily.mono}", "fontSize": "1.250rem", "fontWeight": 500, "lineHeight": 1.40, "letterSpacing": "0" } },
    "lead":    { "$type": "typography", "$value": { "fontFamily": "{fontFamily.sans}", "fontSize": "1.250rem", "fontWeight": 400, "lineHeight": 1.50, "letterSpacing": "-0.005em" } },
    "body-md": { "$type": "typography", "$value": { "fontFamily": "{fontFamily.sans}", "fontSize": "1.000rem", "fontWeight": 400, "lineHeight": 1.60, "letterSpacing": "0" } },
    "body-sm": { "$type": "typography", "$value": { "fontFamily": "{fontFamily.sans}", "fontSize": "0.800rem", "fontWeight": 500, "lineHeight": 1.50, "letterSpacing": "0.01em" } },
    "label-caps": { "$type": "typography", "$value": { "fontFamily": "{fontFamily.sans}", "fontSize": "0.640rem", "fontWeight": 600, "lineHeight": 1.40, "letterSpacing": "0.04em" } },
    "code-inline": { "$type": "typography", "$value": { "fontFamily": "{fontFamily.mono}", "fontSize": "0.875rem", "fontWeight": 400, "lineHeight": 1.50, "letterSpacing": "0" } },
    "code-block":  { "$type": "typography", "$value": { "fontFamily": "{fontFamily.mono}", "fontSize": "0.875rem", "fontWeight": 400, "lineHeight": 1.65, "letterSpacing": "0" } }
  },

  "spacing": {
    "none": { "$type": "dimension", "$value": "0" },
    "xxs":  { "$type": "dimension", "$value": "2px" },
    "xs":   { "$type": "dimension", "$value": "8px" },
    "sm":   { "$type": "dimension", "$value": "16px" },
    "md":   { "$type": "dimension", "$value": "24px" },
    "lg":   { "$type": "dimension", "$value": "32px" },
    "xl":   { "$type": "dimension", "$value": "48px" },
    "xxl":  { "$type": "dimension", "$value": "96px" }
  },

  "borderRadius": {
    "none": { "$type": "dimension", "$value": "0" },
    "xs":   { "$type": "dimension", "$value": "2px" },
    "sm":   { "$type": "dimension", "$value": "4px" },
    "md":   { "$type": "dimension", "$value": "6px" },
    "lg":   { "$type": "dimension", "$value": "8px" },
    "xl":   { "$type": "dimension", "$value": "12px" },
    "full": { "$type": "dimension", "$value": "9999px" }
  },

  "elevation": {
    "flat":    { "$type": "shadow", "$value": "none" },
    "raised":  { "$type": "shadow", "$value": "0 1px 0 0 #2D3441" },
    "card":    { "$type": "shadow", "$value": "0 1px 2px 0 rgba(0,0,0,0.35)" },
    "popover": { "$type": "shadow", "$value": "0 8px 24px -4px rgba(0,0,0,0.45), 0 0 0 1px #2D3441" },
    "modal":   { "$type": "shadow", "$value": "0 24px 64px -8px rgba(0,0,0,0.55), 0 0 0 1px #3A4250" }
  },

  "duration": {
    "instant": { "$type": "duration", "$value": "0ms" },
    "fast":    { "$type": "duration", "$value": "100ms" },
    "base":    { "$type": "duration", "$value": "150ms" },
    "slow":    { "$type": "duration", "$value": "300ms" },
    "pulse":   { "$type": "duration", "$value": "2000ms" }
  },

  "easing": {
    "out":    { "$type": "cubicBezier", "$value": [0.2, 0, 0, 1] },
    "in-out": { "$type": "cubicBezier", "$value": [0.4, 0, 0.2, 1] },
    "linear": { "$type": "cubicBezier", "$value": [0, 0, 1, 1] }
  },

  "breakpoint": {
    "sm":  { "$type": "dimension", "$value": "640px" },
    "md":  { "$type": "dimension", "$value": "768px" },
    "lg":  { "$type": "dimension", "$value": "1024px" },
    "xl":  { "$type": "dimension", "$value": "1280px" },
    "xxl": { "$type": "dimension", "$value": "1536px" }
  },

  "container": {
    "prose":     { "$type": "dimension", "$value": "720px" },
    "container": { "$type": "dimension", "$value": "1280px" },
    "modal":     { "$type": "dimension", "$value": "560px" },
    "toast":     { "$type": "dimension", "$value": "360px" }
  },

  "sizing": {
    "control-height":      { "$type": "dimension", "$value": "40px" },
    "control-height-touch":{ "$type": "dimension", "$value": "44px" },
    "topbar":              { "$type": "dimension", "$value": "64px" },
    "sidebar":             { "$type": "dimension", "$value": "240px" },
    "sidebar-md":          { "$type": "dimension", "$value": "200px" },
    "icon-sm":             { "$type": "dimension", "$value": "16px" },
    "icon-md":             { "$type": "dimension", "$value": "20px" },
    "icon-lg":             { "$type": "dimension", "$value": "24px" },
    "icon-xl":             { "$type": "dimension", "$value": "32px" },
    "status-dot":          { "$type": "dimension", "$value": "6px" },
    "status-dot-hit":      { "$type": "dimension", "$value": "12px" }
  },

  "focus": {
    "ring-width":  { "$type": "dimension", "$value": "2px" },
    "ring-offset": { "$type": "dimension", "$value": "2px" },
    "ring-color":  { "$type": "color", "$value": "{color.primary}" }
  }
}
